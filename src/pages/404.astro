---
import Base from '../layouts/Base.astro';
---
<Base title="Not found">
  <section class="hero">
    <div class="wrap">
      <span class="lam-mark" aria-hidden="true">&lambda;</span>
      <span class="kicker mono">Error 404</span>
      <h1>This page could not be resolved.</h1>
      <p class="lede">The path you followed doesn&rsquo;t match any entry. Head back to the <a href="/" style="color:var(--accent);text-decoration:underline;text-underline-offset:3px;">writing index</a>.</p>
    </div>
  </section>
</Base>
